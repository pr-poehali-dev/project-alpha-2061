{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET list submissions",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"submissions": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST generate missing fields",
      "method": "POST",
      "path": "/?action=generate",
      "body": {"name": "", "telegram_contact": ""},
      "expectedStatus": 400
    },
    {
      "name": "GET single missing id",
      "method": "GET",
      "path": "/?action=get",
      "expectedStatus": 400
    },
    {
      "name": "POST get_upload_url",
      "method": "POST",
      "path": "/?action=get_upload_url",
      "body": {"filename": "test.pdf", "prefix": "old", "content_type": "application/pdf"},
      "expectedStatus": 200
    }
  ]
}